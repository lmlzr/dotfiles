set $tertiary           #bfc4eb
set $error              #ffb4ab
set $surface            #111415
set $on_surface         #e1e3e4
set $on_surface_variant #bfc8cb
set $outline            #899295

## Window Colours
# class                 border    backgr.   text                indicator  child_border
