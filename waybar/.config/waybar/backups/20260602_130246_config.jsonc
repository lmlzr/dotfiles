[
    {
        "position": "top",
        "height": 46,
        "spacing": 6,
        "margin-top": 0,
        "margin-bottom": 0,
        "margin-left": 0,
        "margin-right": 0,
        "modules-left": [
            "custom/arch",
            "hyprland/workspaces",
            "hyprland/window"
        ],
        "modules-center": [
            "clock"
        ],
        "modules-right": [
            "tray",
            "pulseaudio",
            "network",
            "memory",
            "cpu",
            "battery",
            "custom/swaync",
            "custom/settings",
            "custom/power"
        ],
        "hyprland/workspaces": {
            "format": "{id}",
            "on-scroll-up": "hyprctl dispatch workspace e-1",
            "on-scroll-down": "hyprctl dispatch workspace e+1",
            "persistent-workspaces": {
                "*": [
                    1,
                    2,
                    3,
                    4,
                    5
                ]
            },
            "anim-color-1": "#7aa2f7",
            "anim-color-2": "#bb9af7",
            "anim-duration": 3,
            "button-radius": 20,
            "button-pad-v": 0,
            "button-pad-h": 4,
            "button-minw": 35
        },
        "hyprland/window": {
            "format": "{}",
            "max-length": 60,
            "separate-outputs": true
        },
        "clock": {
            "format": "{:%H:%M  |  %A %d %B}",
            "timezone": "America/Monterrey",
            "locale": "es_MX.utf8",
            "interval": 1,
            "on-click": "flatpak run com.ml4w.calendar",
            "tooltip": true,
            "_inverted": false
        },
        "cpu": {
            "format": "¾░Źø {usage}%",
            "tooltip": true,
            "interval": 2
        },
        "memory": {
            "format": "¾░Šå {used:0.1f}G",
            "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
            "interval": 5,
            "_inverted": false
        },
        "network": {
            "format-wifi": "¾░¢® {signalStrength}%",
            "format-ethernet": "",
            "format-disconnected": "",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\nŌåæ {bandwidthUpBits}  Ōåō {bandwidthDownBits}",
            "on-click": "nm-connection-editor",
            "interval": 2,
            "_inverted": false
        },
        "bluetooth": {
            "format": "¾░é»",
            "format-disabled": "¾░é▓",
            "format-connected": "¾░é▒ {device_alias}",
            "on-click": "/usr/bin/blueman-manager",
            "interval": 30,
            "tooltip": true,
            "_inverted": false
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "¾░Ø¤ mute",
            "format-icons": {
                "default": [
                    "¾░Ģ┐",
                    "¾░¢Ć",
                    "¾░ĢŠ"
                ]
            },
            "on-click": "pavucontrol",
            "scroll-step": 5,
            "_inverted": false
        },
        "wireplumber": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 12'>¾░ĢŠ</span> {volume}%",
            "format-muted": "<span font='JetBrainsMono Nerd Font Mono 12'>¾░Ø¤</span> mute",
            "on-click": "pavucontrol",
            "scroll-step": 5,
            "_inverted": false
        },
        "battery": {
            "format": "{icon} {capacity}%",
            "format-icons": [
                "¾░ü║",
                "¾░ü╝",
                "¾░üŠ",
                "¾░éĆ",
                "¾░éé",
                "¾░ü╣"
            ],
            "format-charging": "¾░éä {capacity}%",
            "format-plugged": "¾░Üź {capacity}%",
            "states": {
                "warning": 30,
                "critical": 15
            },
            "_inverted": false
        },
        "backlight": {
            "format": "{icon} {percent}%",
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "_inverted": false
        },
        "idle_inhibitor": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 12'>{icon}</span>",
            "format-icons": {
                "activated": "¾░Š¬",
                "deactivated": "¾░Š®"
            },
            "_inverted": false
        },
        "mpris": {
            "format": "{player_icon} {title}",
            "format-paused": "{player_icon}  {title}",
            "interval": 1,
            "max-length": 40,
            "_inverted": false
        },
        "tray": {
            "spacing": 8,
            "icon-size": 18
        },
        "custom/arch": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 22' color='#7aa2f7'>¾▒äģ</span>",
            "on-click": "$HOME/.local/bin/vsfetch",
            "tooltip": false,
            "arch-icon-glyph": "¾▒äģ",
            "arch-pad-left": 15,
            "arch-pad-right": 10,
            "_inverted": false
        },
        "custom/weather": {
            "format": "{}",
            "exec": "$HOME/.config/waybar/scripts/weather.py",
            "return-type": "json",
            "interval": 3600,
            "tooltip": true,
            "on-click": "flatpak run io.github.amit9838.mousam",
            "_inverted": false
        },
        "custom/updates": {
            "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"¾░Ü░ '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"¾░Ü░ 0\",\"class\":\"updated\"}'",
            "return-type": "json",
            "interval": 60,
            "tooltip": false,
            "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh",
            "_inverted": false
        },
        "custom/swaync": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
            "format-icons": {
                "none": "¾░éÜ",
                "notification": "¾░é£",
                "dnd-none": "¾░éø",
                "dnd-notification": "¾░éø"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true,
            "tooltip": false,
            "_inverted": false
        },
        "custom/power": {
            "format": "ŌÅ╗",
            "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
            "tooltip": false,
            "_inverted": false
        },
        "custom/settings": {
            "format": "¾░Æō",
            "on-click": "vswaybar-studio",
            "tooltip": false,
            "_inverted": false
        },
        "custom/claudebar": {
            "exec": "claudebar --format '{session_bar} {session_pct}% ┬Ę {session_reset}'",
            "return-type": "json",
            "interval": 30,
            "signal": 13,
            "tooltip": true,
            "on-click": "xdg-open https://claude.ai/settings/usage"
        },
        "custom/bar-cpu": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type cpu",
            "return-type": "json",
            "interval": 2,
            "tooltip": true,
            "_inverted": false
        },
        "custom/bar-mem": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type mem",
            "return-type": "json",
            "interval": 5,
            "tooltip": true,
            "_inverted": false
        },
        "custom/bar-vol": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type vol",
            "return-type": "json",
            "interval": 2,
            "tooltip": true,
            "on-click": "pavucontrol",
            "_inverted": false
        },
        "custom/bar-wifi": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type wifi",
            "return-type": "json",
            "interval": 5,
            "tooltip": true,
            "on-click": "nm-connection-editor",
            "_inverted": false
        },
        "name": "bar"
    }
]